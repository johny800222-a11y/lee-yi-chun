# 複製此檔為 .env，填入真實憑證後執行
# cp .env.example .env

# Binance API（期貨帳號，開啟 Futures 權限）
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Telegram Bot
# 1. 向 @BotFather 建立 bot，取得 token
# 2. 先對 bot 發一則訊息，再用以下指令取得 chat_id：
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# JSONBin.io — 雲端狀態同步（讓 Render 上的 App 能讀到 bot 資料）
# 1. 去 https://jsonbin.io 免費註冊
# 2. Dashboard → API Keys → 複製 Master Key
# 3. 建立兩個 Bin（一個給 bot state，一個給手動持倉），複製 Bin ID
JSONBIN_API_KEY=your_jsonbin_master_key_here
JSONBIN_BIN_ID=your_bot_state_bin_id_here
JSONBIN_MANUAL_BIN_ID=your_manual_positions_bin_id_here
